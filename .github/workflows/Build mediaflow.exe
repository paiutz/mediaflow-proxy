name: Build mediaflow.exe

on:
  push:
    paths:
      - '**.py'
      - '.github/workflows/**'
  workflow_dispatch:

jobs:
  build-windows-exe:
    runs-on: windows-latest

    steps:
    - name: Checkout repo
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: 3.11

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt
        pip install pyinstaller python-dotenv

    - name: Auto-generate `.env` file
      run: |
        echo API_PASSWORD=changeme123 > .env

    - name: Build with PyInstaller
      run: |
        pyinstaller --onefile --name mediaflow main.py

    - name: Upload artifact
      uses: actions/upload-artifact@v4
      with:
        name: mediaflow-exe
        path: dist/mediaflow.exe
